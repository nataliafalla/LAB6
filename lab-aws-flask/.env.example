# Flask
SECRET_KEY=cambia-esto-por-un-string-aleatorio-largo

# Admin por defecto (se crea solo si no existe ninguno)
ADMIN_USER=admin
ADMIN_PASSWORD=Admin123!

# RDS MySQL
DB_HOST=tu-instancia.xxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=tu_password_rds
DB_NAME=adminpanel

# AWS S3
AWS_REGION=us-east-1
S3_BUCKET=mi-bucket-perfiles-lab

# NOTA: En EC2 con IAM Role NO se ponen AWS_ACCESS_KEY_ID ni AWS_SECRET_ACCESS_KEY.
# boto3 toma las credenciales del rol automáticamente.
# Solo para pruebas locales puedes descomentar:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
